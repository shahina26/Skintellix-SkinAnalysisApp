# ── Server ────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/skintellix
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# ── AI / ML (Google Vision or custom model) ──────────
GOOGLE_VISION_API_KEY=your_google_vision_api_key
OPENAI_API_KEY=your_openai_api_key

# ── Price Scraping Proxies ────────────────────────────
SCRAPER_API_KEY=your_scraper_api_key

# ── External APIs ─────────────────────────────────────
AMAZON_ASSOCIATE_TAG=skintellix-21
FLIPKART_AFFILIATE_ID=your_flipkart_affiliate_id
NYKAA_AFFILIATE_ID=your_nykaa_affiliate_id

# ── Email ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ── Uploads ──────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5mb
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret
